# Environment Configuration
ENVIRONMENT=development

# API Configuration
API_URL=http://localhost:8001

# CORS Configuration (for production)
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com


# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Monobank Payment (optional)
MONOBANK_API_TOKEN=your_monobank_api_token_here

# OpenAI API (for chat feature)
OPENAI_API_KEY=your_openai_api_key_here
# Delivery API keys
# Keep delivery provider keys on backend only. Do not expose them as EXPO_PUBLIC_* in the mobile app.
NOVA_POSHTA_API_KEY=your_nova_poshta_api_key_here
NOVA_POSHTA_INTERNATIONAL_API_KEY=your_nova_poshta_international_api_key_here
UKRPOSHTA_API_KEY=your_ukrposhta_bearer_ecom_here
UKRPOSHTA_BEARER_ECOM=your_ukrposhta_bearer_ecom_here
UKRPOSHTA_COUNTERPARTY_TOKEN=your_ukrposhta_counterparty_token_here
UKRPOSHTA_BEARER_STATUS_TRACKING=your_ukrposhta_status_tracking_bearer_here
MEEST_API_KEY=your_meest_api_key_here
