{
  "cli": {
    "version": ">= 5.2.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://app.dikoros.ua",
        "EXPO_PUBLIC_ENVIRONMENT": "production",
        "EXPO_PUBLIC_USE_LOCAL": "0"
      },
      "android": {
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "environment": "production",
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://app.dikoros.ua",
        "EXPO_PUBLIC_ENVIRONMENT": "production",
        "EXPO_PUBLIC_USE_LOCAL": "0"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://app.dikoros.ua",
        "EXPO_PUBLIC_ENVIRONMENT": "production",
        "EXPO_PUBLIC_USE_LOCAL": "0",
        "EXPO_PUBLIC_IMAGE_URL_VERSION": "2"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}


