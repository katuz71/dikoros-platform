{
  "philosophy": "Dikoros \u2014 \u0446\u0435 \u043d\u0435 \u043f\u0440\u043e\u0441\u0442\u043e \u043c\u0430\u0433\u0430\u0437\u0438\u043d, \u0430 \u043f\u043e\u0432\u043d\u0438\u0439 \u0446\u0438\u043a\u043b \u0432\u0438\u0440\u043e\u0431\u043d\u0438\u0446\u0442\u0432\u0430. \u041c\u0438 \u0437\u0431\u0438\u0440\u0430\u0454\u043c\u043e \u0434\u0438\u043a\u043e\u0440\u043e\u0441\u0438 \u0432 \u0435\u043a\u043e\u043b\u043e\u0433\u0456\u0447\u043d\u043e \u0447\u0438\u0441\u0442\u0438\u0445 \u043b\u0456\u0441\u0430\u0445 \u041f\u043e\u043b\u0456\u0441\u0441\u044f. \u041d\u0430\u0448\u0430 \u043c\u0435\u0442\u0430 \u2014 \u043d\u0430\u0434\u0430\u0442\u0438 \u0447\u0438\u0441\u0442\u0438\u0439 \u043f\u0440\u043e\u0434\u0443\u043a\u0442 \u0434\u043b\u044f \u0431\u0456\u043e\u0445\u0430\u043a\u0456\u043d\u0433\u0443 \u0442\u0430 \u0437\u0434\u043e\u0440\u043e\u0432\u2019\u044f.",
  "production": "\u0412\u0438\u0440\u043e\u0431\u043d\u0438\u0446\u0442\u0432\u043e \u0437\u043d\u0430\u0445\u043e\u0434\u0438\u0442\u044c\u0441\u044f \u0432 \u0427\u0435\u0440\u043d\u0456\u0433\u0456\u0432\u0441\u044c\u043a\u0456\u0439 \u043e\u0431\u043b\u0430\u0441\u0442\u0456, \u0441. \u0416\u0430\u0432\u0438\u043d\u043a\u0430. \u041c\u0438 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0454\u043c\u043e \u043c\u0435\u0442\u043e\u0434 \u043d\u0438\u0437\u044c\u043a\u043e\u0442\u0435\u043c\u043f\u0435\u0440\u0430\u0442\u0443\u0440\u043d\u043e\u0433\u043e \u0441\u0443\u0448\u0456\u043d\u043d\u044f 40-45\u00b0C. \u0423\u0432\u0435\u0441\u044c \u043f\u0440\u043e\u0434\u0443\u043a\u0442 \u043f\u0440\u043e\u0445\u043e\u0434\u0438\u0442\u044c \u0440\u0443\u0447\u043d\u0435 \u043e\u0447\u0438\u0449\u0435\u043d\u043d\u044f \u0442\u0430 \u043a\u043e\u043d\u0442\u0440\u043e\u043b\u044c \u044f\u043a\u043e\u0441\u0442\u0456.",
  "quality_control": "\u041f\u0440\u043e\u0434\u0443\u043a\u0446\u0456\u044f \u0441\u0435\u0440\u0442\u0438\u0444\u0456\u043a\u043e\u0432\u0430\u043d\u0430. \u041c\u0438 \u043f\u0440\u0430\u0446\u044e\u0454\u043c\u043e \u043e\u0444\u0456\u0446\u0456\u0439\u043d\u043e. \u041a\u043e\u0436\u043d\u0430 \u043f\u0430\u0440\u0442\u0456\u044f \u043f\u0440\u043e\u0445\u043e\u0434\u0438\u0442\u044c \u043f\u0435\u0440\u0435\u0432\u0456\u0440\u043a\u0443 \u043d\u0430 \u0447\u0438\u0441\u0442\u043e\u0442\u0443 \u0442\u0430 \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u043d\u0456\u0441\u0442\u044c \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u0430\u043c \u044f\u043a\u043e\u0441\u0442\u0456.",
  "shipping": "\u0414\u043e\u0441\u0442\u0430\u0432\u043a\u0430 \u0437\u0434\u0456\u0439\u0441\u043d\u044e\u0454\u0442\u044c\u0441\u044f \u041d\u043e\u0432\u043e\u044e \u041f\u043e\u0448\u0442\u043e\u044e \u043f\u043e \u0432\u0441\u0456\u0439 \u0423\u043a\u0440\u0430\u0457\u043d\u0456. \u042f\u043a\u0449\u043e \u0437\u0430\u043c\u043e\u0432\u043b\u0435\u043d\u043d\u044f \u043e\u0444\u043e\u0440\u043c\u043b\u0435\u043d\u0435 \u0434\u043e 15:00 \u2014 \u0432\u0456\u0434\u043f\u0440\u0430\u0432\u043a\u0430 \u0432 \u0442\u043e\u0439 \u0441\u0430\u043c\u0438\u0439 \u0434\u0435\u043d\u044c, \u044f\u043a\u0449\u043e \u043f\u0456\u0437\u043d\u0456\u0448\u0435 \u2014 \u043d\u0430 \u043d\u0430\u0441\u0442\u0443\u043f\u043d\u0438\u0439. \u0423 \u0441\u0435\u0440\u0435\u0434\u043d\u044c\u043e\u043c\u0443 \u0434\u043e\u0441\u0442\u0430\u0432\u043a\u0430 \u0437\u0430\u0439\u043c\u0430\u0454 1-2 \u0434\u043d\u0456.",
  "payment": "\u0412\u0430\u0440\u0456\u0430\u043d\u0442\u0438 \u043e\u043f\u043b\u0430\u0442\u0438: \u043d\u0430\u043a\u043b\u0430\u0434\u0435\u043d\u0438\u0439 \u043f\u043b\u0430\u0442\u0456\u0436 \u043f\u0440\u0438 \u043e\u0442\u0440\u0438\u043c\u0430\u043d\u043d\u0456, \u043e\u043f\u043b\u0430\u0442\u0430 \u0437\u0430 \u0440\u0435\u043a\u0432\u0456\u0437\u0438\u0442\u0430\u043c\u0438 \u0430\u0431\u043e \u043e\u043d\u043b\u0430\u0439\u043d-\u043e\u043f\u043b\u0430\u0442\u0430 \u043d\u0430 \u0441\u0430\u0439\u0442\u0456/\u0432 \u0437\u0430\u0441\u0442\u043e\u0441\u0443\u043d\u043a\u0443.",
  "returns": "\u0417\u0433\u0456\u0434\u043d\u043e \u0456\u0437 \u0437\u0430\u043a\u043e\u043d\u043e\u043c \u0423\u043a\u0440\u0430\u0457\u043d\u0438, \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0438 \u0445\u0430\u0440\u0447\u0443\u0432\u0430\u043d\u043d\u044f \u043d\u0430\u043b\u0435\u0436\u043d\u043e\u0457 \u044f\u043a\u043e\u0441\u0442\u0456 \u043f\u043e\u0432\u0435\u0440\u043d\u0435\u043d\u043d\u044e \u043d\u0435 \u043f\u0456\u0434\u043b\u044f\u0433\u0430\u044e\u0442\u044c. \u0410\u043b\u0435 \u044f\u043a\u0449\u043e \u0443\u043f\u0430\u043a\u043e\u0432\u043a\u0430 \u043d\u0435 \u0432\u0456\u0434\u043a\u0440\u0438\u0442\u0430, \u043c\u043e\u0436\u043b\u0438\u0432\u0438\u0439 \u043e\u0431\u043c\u0456\u043d \u0430\u0431\u043e \u043f\u043e\u0432\u0435\u0440\u043d\u0435\u043d\u043d\u044f \u043f\u0440\u043e\u0442\u044f\u0433\u043e\u043c 14 \u0434\u043d\u0456\u0432. \u0423 \u0440\u0430\u0437\u0456 \u0431\u0440\u0430\u043a\u0443 \u2014 \u0437\u0430\u043c\u0456\u043d\u0430 \u0437\u0430 \u043d\u0430\u0448 \u0440\u0430\u0445\u0443\u043d\u043e\u043a.",
  "legal_and_contacts": "\u041c\u0438 \u2014 \u043e\u0444\u0456\u0446\u0456\u0439\u043d\u043e \u0437\u0430\u0440\u0435\u0454\u0441\u0442\u0440\u043e\u0432\u0430\u043d\u0438\u0439 \u0431\u0456\u0437\u043d\u0435\u0441. \u0422\u0435\u043b\u0435\u0444\u043e\u043d: (063) 25 26 8 24. Email: dikorosua@gmail.com. \u0410\u0434\u0440\u0435\u0441\u0430: \u0427\u0435\u0440\u043d\u0456\u0433\u0456\u0432\u0441\u044c\u043a\u0430 \u043e\u0431\u043b., \u0441. \u0416\u0430\u0432\u0438\u043d\u043a\u0430, \u0432\u0443\u043b. \u0406\u043b\u043b\u0456\u043d\u0441\u044c\u043a\u0430 2\u0430.",
  "product_expertise": "\u041c\u0443\u0445\u043e\u043c\u043e\u0440\u0438, \u0407\u0436\u043e\u0432\u0438\u043a \u0433\u0440\u0435\u0431\u0456\u043d\u0447\u0430\u0441\u0442\u0438\u0439, \u041a\u043e\u0440\u0434\u0438\u0446\u0435\u043f\u0441, \u0427\u0430\u0433\u0430, \u0420\u0435\u0439\u0448\u0456 \u0442\u0430 \u0456\u043d\u0448\u0456 \u0433\u0440\u0438\u0431\u0438 \u0454 \u0444\u0443\u043d\u043a\u0446\u0456\u043e\u043d\u0430\u043b\u044c\u043d\u0438\u043c \u0445\u0430\u0440\u0447\u0443\u0432\u0430\u043d\u043d\u044f\u043c \u0456 \u0434\u0456\u0454\u0442\u0438\u0447\u043d\u0438\u043c\u0438 \u0434\u043e\u0431\u0430\u0432\u043a\u0430\u043c\u0438. \u0424\u043e\u0440\u043c\u0443\u043b\u044e\u0439 \u043a\u043e\u0440\u0438\u0441\u0442\u044c \u043e\u0431\u0435\u0440\u0435\u0436\u043d\u043e: \u043f\u0456\u0434\u0442\u0440\u0438\u043c\u0443\u0454, \u0441\u043f\u0440\u0438\u044f\u0454, \u043c\u043e\u0436\u0435 \u0434\u043e\u043f\u043e\u043c\u043e\u0433\u0442\u0438, \u0431\u0435\u0437 \u043c\u0435\u0434\u0438\u0447\u043d\u0438\u0445 \u043e\u0431\u0456\u0446\u044f\u043d\u043e\u043a \u043b\u0456\u043a\u0443\u0432\u0430\u043d\u043d\u044f."
}